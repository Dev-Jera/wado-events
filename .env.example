APP_NAME=Laravel
APP_ENV=local
APP_KEY=
TICKET_SIGNING_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# Production note: use mysql or pgsql for checkout row-level locking.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Keep host-relative by default so local dev works on localhost and 127.0.0.1.
FILESYSTEM_PUBLIC_URL=/storage
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# MarzPay Integration - https://wallet.wearemarz.com/api/v1/collect-money
# Get your credentials from: https://dashboard.wearemarz.com
MARZEPAY_BASE_URL=https://wallet.wearemarz.com/api/v1
MARZEPAY_API_KEY=your_api_key_here
MARZEPAY_API_SECRET=your_api_secret_here
MARZEPAY_WEBHOOK_SECRET=your_webhook_secret_here
MARZEPAY_COUNTRY=UG
MARZEPAY_CALLBACK_PATH=payments/marzepay/webhook
MARZEPAY_REFUND_PATH=refund-money
MARZEPAY_TIMEOUT=30

# Africa's Talking SMS (optional, recommended for production)
AFRICASTALKING_BASE_URL=https://api.africastalking.com
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your_africas_talking_api_key_here
AFRICASTALKING_FROM=

WALKIN_CASH_MAX_TICKETS_PER_SALE=6
WALKIN_CASH_DAILY_LIMIT_UGX=2000000

VITE_APP_NAME="${APP_NAME}"

